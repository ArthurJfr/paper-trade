# ──────────────────────────────────────────────
# Paper-Trade · variables d'environnement
# Copie ce fichier en `.env` et adapte.
# ──────────────────────────────────────────────

# Port exposé sur l'hôte (utilisé par docker-compose)
APP_PORT=3000
API_PORT=4000
POSTGRES_PORT=5432
ADMINER_PORT=8080
MONGO_PORT=27017
MONGO_EXPRESS_PORT=8081

# Port interne de l'app (à laisser à 3000 en Docker)
PORT=3000
HOST=0.0.0.0

# URL du backend (API Fastify/Express exposée sur le port 4000).
# - En dev local (npm run dev hors Docker) : http://localhost:4000
# - En Docker (compose up)                 : http://api:4000 (hostname du service)
#   → surchargé automatiquement par docker-compose.yml pour les services app / app-dev,
#     donc laisser localhost ici pour le workflow dev local.
#
# Nuxt/Nitro override runtimeConfig au runtime uniquement via des variables préfixées
# NUXT_* (sinon la valeur est figée au build). On expose donc NUXT_BACKEND_API_URL
# en plus pour que l'image Docker buildée puisse être reconfigurée sans rebuild.
BACKEND_API_URL=http://localhost:4000
BACKEND_API_BASE_PATH=/api/v1
NUXT_BACKEND_API_URL=http://localhost:4000
NUXT_BACKEND_API_BASE_PATH=/api/v1

# PostgreSQL
POSTGRES_DB=paper_trade
POSTGRES_USER=paper_trade
POSTGRES_PASSWORD=paper_trade_pwd

# API Auth (JWT)
REQUIRE_AUTH=false
JWT_SECRET=change-me
API_USER=admin
API_PASSWORD=admin

# CoinGecko — optionnel, une clé démo augmente le rate-limit
COINGECKO_API_KEY=

# Paper trading
INITIAL_BALANCE_USDC=10000
TRADING_FEE_BPS=10
# Exécution des ordres limites + évaluation des alertes (ms)
PAPER_TRADE_JOB_TICK_MS=3000

# MongoDB (data science / notebook)
MONGO_DB=paper_trade_data
MONGO_COLLECTION_CANDLES=btc_15m_clean
